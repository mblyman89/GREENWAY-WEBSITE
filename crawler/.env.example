# Greenway crawler — environment template. Copy to `.env` and fill in.
# NEVER commit the real .env (it's gitignored).

# --- Auth between the Next.js site and this worker -----------------------------
# A long random shared secret. The site sends it as `X-Crawler-Secret`; the
# worker rejects any request without the exact match. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(40))"
CRAWLER_SHARED_SECRET=change-me-to-a-long-random-string

# --- Supabase (the worker writes drafts directly to ai_suggestions) ------------
# Use the SERVICE ROLE key (server-side only — this worker is not public).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI provider (OpenAI-compatible; same values as the site) ------------------
# Leave AI_API_KEY empty to run the pipeline WITHOUT the LLM step (CSS-first
# extraction still works and is often enough). When set, the schema-extraction
# step is enabled.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=

# --- Crawl politeness ----------------------------------------------------------
# Per-domain minimum delay (seconds) and a global cache TTL (seconds).
CRAWL_MIN_DELAY_SECONDS=2.0
CRAWL_CACHE_TTL_SECONDS=86400
# A descriptive UA so site owners can identify/contact us. Include a real email.
CRAWL_USER_AGENT=GreenwayBot/1.0 (+https://greenwaymarijuana.com; contact: web@greenwaymarijuana.com)
# Respect robots.txt (true in production; can disable for local testing only).
CRAWL_RESPECT_ROBOTS=true

# --- Crawl hardening (DF-7) ----------------------------------------------------
# Send a realistic, rotating modern-browser User-Agent + full browser headers so
# public pages serve the same content a human visitor sees. This is parity with a
# normal browser, NOT evasion of an anti-bot system. Set false to always send the
# bare CRAWL_USER_AGENT above.
CRAWL_REALISTIC_HEADERS=true
# Retry transient failures (429/5xx/network) with exponential backoff + jitter,
# honoring a server's Retry-After header.
CRAWL_MAX_RETRIES=3
CRAWL_BACKOFF_BASE_SECONDS=1.5
CRAWL_BACKOFF_MAX_SECONDS=30
# Optional transparent egress proxy (e.g. a reputable commercial proxy used at
# polite rates). Leave empty for none. Standard HTTP_PROXY/HTTPS_PROXY also work.
CRAWL_PROXY_URL=
# Optional per-domain allow-list (comma-separated hostnames). Empty = allow any
# host a staff member submits. Set to lock the worker to brands you carry.
CRAWL_ALLOW_DOMAINS=

# --- Social: Meta Graph API (DF-9, sanctioned) ---------------------------------
# The legitimate way to read vendors' PUBLIC Instagram content: you authenticate
# as Greenway (your own Page + IG Business account) and use Instagram Business
# Discovery. These are ACCESS TOKENS generated in the Meta developer console —
# NEVER passwords. Leave empty to disable social features. See docs/SOCIAL_SETUP.md.
META_GRAPH_TOKEN=
META_IG_BUSINESS_ID=
META_GRAPH_VERSION=v21.0

# --- Service ------------------------------------------------------------------
CRAWLER_PORT=8200
# Where on-disk caches/logs live (relative to the crawler/ folder).
CRAWL_CACHE_DIR=.cache
