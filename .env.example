# Greenway Marijuana — environment variables (copy to .env.local and fill in)
# All NEXT_PUBLIC_* values are exposed to the browser.

# --- Analytics (optional) ---------------------------------------------------
# Google Analytics 4 measurement ID. When unset, analytics is fully disabled
# (no scripts loaded, no tracking). Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# --- Leafly menu (optional) -------------------------------------------------
# When unset, the menu falls back to the bundled sandbox catalog.
LEAFLY_API_BASE_URL=
LEAFLY_API_KEY=

# --- Loyalty email (optional) -----------------------------------------------
# Resend API key used to deliver loyalty sign-up confirmations. When unset,
# sign-ups are accepted but no email is sent.
RESEND_API_KEY=
LOYALTY_FROM_EMAIL=

# Order notifications (Slice 7). When ORDER_EMAIL_FROM is unset, order emails
# are skipped (orders still save). ORDER_STAFF_EMAILS is a comma-separated list
# of staff recipients alerted on every new pickup order.
ORDER_EMAIL_FROM=
ORDER_STAFF_EMAILS=

# --- Supabase (back office) -------------------------------------------------
# Project URL and anon key are safe for the browser. The service-role key is
# SERVER-ONLY — never expose it to the client. Get these from your Supabase
# project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails auto-promoted to the "owner" role on first
# login (bootstrap admins). Example: you@greenwaymarijuana.com
ADMIN_BOOTSTRAP_EMAILS=

# --- AI Enrichment Engine (optional) ----------------------------------------
# When AI_API_KEY is unset, AI features soft-disable (buttons hidden) and the
# rest of the back office works normally. AI output is always a DRAFT a staff
# member must Accept before it reaches the public site (compliance-gated).
# AI_BASE_URL defaults to OpenAI; point it at any OpenAI-compatible endpoint
# (OpenRouter, Together, a local gateway, etc.). AI_MODEL defaults to gpt-4o-mini.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
